# ============================================================
# ListingContent Co — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub — it is already in .gitignore.
# ============================================================

# ------------------------------------------------------------
# ANTHROPIC API
# ------------------------------------------------------------
# Get your key at: https://console.anthropic.com/account/keys
# Used by: scripts/process_catalog.py, scripts/webhook_server.py
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ------------------------------------------------------------
# STRIPE
# ------------------------------------------------------------
# Webhook secret — get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# Used to verify incoming Stripe webhook events are genuine
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Stripe Secret Key — get from Stripe Dashboard → Developers → API Keys
# Used for server-side Stripe API calls (retrieving session data, etc.)
STRIPE_SECRET_KEY=sk_live_your-secret-key-here

# Your $497 Payment Link URL (already configured, for reference)
STRIPE_PAYMENT_LINK=https://buy.stripe.com/5kQ7sM8Rt3lE7GLabHfrW05

# ------------------------------------------------------------
# EMAIL
# ------------------------------------------------------------
# The email address used to send onboarding and delivery emails
SENDING_EMAIL_ADDRESS=support@listingcontentco.com

# BCC address for your own records on every outgoing email
BCC_EMAIL_ADDRESS=listingcontentco@gmail.com

# ------------------------------------------------------------
# GOOGLE DRIVE (for automated CSV storage)
# ------------------------------------------------------------
# Folder IDs from your Google Drive setup
GDRIVE_INCOMING_FOLDER_ID=1aBW-EzO5E1CCZSRue7COJJXUJ-zBu4xu
GDRIVE_OPTIMIZED_FOLDER_ID=1GZvimTRVyAGsScbPM3Kcf-j0Uqma635y

# ------------------------------------------------------------
# MAKE.COM WEBHOOKS
# ------------------------------------------------------------
# Webhook URL for the Zero-Touch Fulfillment scenario
# Get this from Make → your scenario → Webhooks module → Copy URL
MAKE_FULFILLMENT_WEBHOOK_URL=https://hook.us2.make.com/your-webhook-id

# Webhook URL for the Phase 2 Draft-Queue scenario (5728637)
MAKE_DRAFT_QUEUE_WEBHOOK_URL=https://hook.us2.make.com/er721th44magnv2qelajxrcygjkiaujb

# ------------------------------------------------------------
# DEPLOYMENT (for webhook_server.py on Render/Railway/Lambda)
# ------------------------------------------------------------
# Port for local development
PORT=8000

# Environment: development | production
NODE_ENV=production

# Base URL of your deployed processor (set after deploying to Render etc.)
PROCESSOR_BASE_URL=https://listingcontent-processor.onrender.com

# ------------------------------------------------------------
# OPTIONAL: TALLY WEBHOOK VERIFICATION
# ------------------------------------------------------------
# If Tally provides a signing secret for webhook verification
TALLY_SIGNING_SECRET=your-tally-signing-secret-here
